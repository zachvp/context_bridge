# Absolute path to the SQLite database.
# Defaults to chat_memory.db next to this file if unset.
CONTEXT_BRIDGE_DB_PATH=/absolute/path/to/chat_memory.db

# HuggingFace model ID for embeddings (must be sentence-transformers compatible).
# Defaults to BAAI/bge-base-en-v1.5 if unset.
# WARNING: changing this after a build triggers a full rebuild on the next run
# (the model mismatch is detected automatically via the meta table).
#CONTEXT_BRIDGE_MODEL=BAAI/bge-base-en-v1.5

# Embedding batch size. Reduce (e.g. 16 or 8) if you hit OOM during build.
# Defaults to 64 if unset.
#CONTEXT_BRIDGE_BATCH_SIZE=64
